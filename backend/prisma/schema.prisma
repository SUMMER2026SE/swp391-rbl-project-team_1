generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  VNPAY
  MOCK
}

enum DoctorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  PENDING
  RESOLVED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String?
  fullName     String?
  avatar       String?
  gender       String?
  address      String?
  dateOfBirth  DateTime?
  role         Role          @default(USER)
  doctorId     String?       @unique  // Link to Doctor record when role = DOCTOR
  
  // Medical Background Fields
  bloodType       String?
  allergies       String?
  chronicDiseases String?
  personalHistory String?
  familyHistory   String?
  // Admin features
  isLocked        Boolean       @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  doctor       Doctor?       @relation(fields: [doctorId], references: [id])
  complaints   Complaint[]
  medicalRecords MedicalRecord[]
  reviews      Review[]
  articles     Article[]     @relation("ArticleAuthor")
  patientProfiles PatientProfile[]
  conversations Conversation[]
  messagesSent  Message[]
}

model OTP {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  doctors     Doctor[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Doctor {
  id              String           @id @default(uuid())
  name            String
  experience      Int
  hospital        String
  avatar          String
  createdAt       DateTime         @default(now())
  appointments    Appointment[]
  doctorSchedules DoctorSchedule[]
  userAccount     User?            // Reverse relation: the User account linked to this Doctor
  specialtyId     String
  specialty       Specialty        @relation(fields: [specialtyId], references: [id])
  
  // Moderation & Control
  status          DoctorStatus     @default(PENDING)
  isLocked        Boolean          @default(false)
  rejectedReason  String?
  
  // Clinic Relation
  clinicId        String?
  clinic          Clinic?          @relation(fields: [clinicId], references: [id])
  // Extra info
  price           Int?
  phone           String?
  description     String?
  medicalRecords  MedicalRecord[]
  certificates    DoctorCertificate[]
  reviews         Review[]
  conversations   Conversation[]
}

model Clinic {
  id          String   @id @default(cuid())
  name        String
  address     String
  image       String?
  doctors     Doctor[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id          String   @id @default(cuid())
  title       String
  content     String
  thumbnail   String?
  type        String   @default("news") // "news" or "epidemic_alert"
  published   Boolean  @default(false)
  authorId    String?
  author      User?    @relation("ArticleAuthor", fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Complaint {
  id            String          @id @default(cuid())
  message       String
  status        ComplaintStatus @default(PENDING)
  adminResponse String?
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime        @default(now())
}

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  doctorId    String
  dayOfWeek   Int      // 0 = Sunday, 1 = Monday, ... 6 = Saturday
  startTime   String   // format HH:MM (24h)
  endTime     String   // format HH:MM (24h)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Appointment {
  id              String            @id @default(uuid())
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  patientProfile  PatientProfile?   @relation(fields: [patientProfileId], references: [id])
  patientProfileId String?
  doctor          Doctor?           @relation(fields: [doctorId], references: [id])
  doctorId        String?
  appointmentDate DateTime
  status          AppointmentStatus @default(PENDING_PAYMENT)
  notes           String?
  cancellationReason String?
  createdAt       DateTime          @default(now())
  
  // New prepayment fields
  transactionCode String?           @unique
  amount          Int               @default(50000)
  paymentProof    String?
  paymentAt       DateTime?
  
  packageId       String?
  medicalPackage  MedicalPackage?   @relation(fields: [packageId], references: [id])
  
  medicalRecord   MedicalRecord?
  review          Review?
  payment         Payment?
  complaints      Complaint[]
}

model MedicalRecord {
  id            String         @id @default(uuid())
  appointmentId String         @unique
  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  doctorId      String
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  patientProfileId String?
  patientProfile   PatientProfile? @relation(fields: [patientProfileId], references: [id])
  diagnosis     String
  notes         String?
  prescriptions Prescription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Prescription {
  id              String        @id @default(uuid())
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id])
  medicationName  String
  dosage          String
  frequency       String
  duration        String
  createdAt       DateTime      @default(now())
}

model DoctorCertificate {
  id          String   @id @default(cuid())

  doctorId    String

  title       String
  issuer      String?
  issuedYear  Int?
  description String?

  imageUrl    String?
  fileUrl     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Review {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Payment {
  id              String        @id @default(uuid())
  appointmentId   String        @unique
  appointment     Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount          Int
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  transactionId   String?       // Transaction ID from gateway (VNPay vnp_TransactionNo)
  paymentGateway  String?       // "VNPAY" or "MOCK"
  payDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model MedicalPackage {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  price       Int           @default(0)
  hospital    String        @default("Bệnh viện Hoàn Mỹ Đà Nẵng")
  estimatedDuration Int     @default(30)
  
  // New Feature 2 Fields
  depositPercentage  Int      @default(100) // % of price to be deposited
  depositAmount      Int?     // If specified, overrides the percentage calculation
  includedServices   String[] @default([]) // Array of services included in the package
  suitableFor        String?  // Target audience or specialties
  preparationGuide   String?  // Preparation instructions
  cancellationPolicy String?  // Cancellation and refund policy
  isRecommended      Boolean  @default(false)
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  appointments Appointment[]
}

model PatientProfile {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  // Basic info
  fullName        String
  dateOfBirth     DateTime?
  gender          String?
  phoneNumber     String?
  cccd            String?  // CCCD/CMND
  ethnicity       String?
  nationality     String?
  address         String?
  
  // Medical Background
  bloodType       String?
  allergies       String?
  chronicDiseases String?
  personalHistory String?
  familyHistory   String?
  
  isPrimary       Boolean  @default(false) // If this is the user's own profile

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, doctorId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}
