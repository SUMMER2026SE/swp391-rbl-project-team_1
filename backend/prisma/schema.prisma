generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  DOCTOR
  CLINIC_MANAGER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum DoctorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  PENDING
  RESOLVED
}

enum NotificationType {
  APPOINTMENT_REMINDER
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  SYSTEM
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?
  fullName       String?
  avatar         String?
  gender         String?
  address        String?
  dateOfBirth    DateTime?
  role           Role            @default(USER)
  doctorId       String?         @unique
  clinicId       String?
  clinic         Clinic?         @relation(fields: [clinicId], references: [id])
  parentId       String?
  parent         User?           @relation("FamilyMembers", fields: [parentId], references: [id])
  familyMembers  User[]          @relation("FamilyMembers")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  appointments   Appointment[]
  doctor         Doctor?         @relation(fields: [doctorId], references: [id])
  complaints     Complaint[]
  medicalRecords MedicalRecord[]
  reviews        Review[]
  healthProfile  HealthProfile?
  notifications  Notification[]
  consentTokens  MedicalConsentToken[]
}

model OTP {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Specialty {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  doctors     Doctor[]
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Doctor {
  id              String           @id @default(uuid())
  name            String
  experience      Int
  hospital        String
  avatar          String
  createdAt       DateTime         @default(now())
  appointments    Appointment[]
  doctorSchedules DoctorSchedule[]
  userAccount     User?
  specialtyId     String
  specialty       Specialty        @relation(fields: [specialtyId], references: [id])
  status          DoctorStatus     @default(PENDING)
  isLocked        Boolean          @default(false)
  rejectedReason  String?
  clinicId        String?
  clinic          Clinic?          @relation(fields: [clinicId], references: [id])
  price           Int?
  phone           String?
  description     String?
  medicalRecords  MedicalRecord[]
  reviews         Review[]
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String
  image     String?
  latitude  Float?
  longitude Float?
  doctors   Doctor[]
  managers  User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id          String     @id @default(cuid())
  title       String
  content     String
  thumbnail   String?
  published   Boolean    @default(false)
  specialtyId String?
  specialty   Specialty? @relation(fields: [specialtyId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Complaint {
  id        String          @id @default(cuid())
  message   String
  status    ComplaintStatus @default(PENDING)
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now())
}

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  doctorId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Appointment {
  id              String            @id @default(uuid())
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  doctorId        String
  appointmentDate DateTime
  status          AppointmentStatus @default(PENDING)
  notes           String?
  queueNumber     Int?
  actualStartTime DateTime?
  createdAt       DateTime          @default(now())
  medicalRecord   MedicalRecord?
  review          Review?
  notifications   Notification[]

  // Video Call fields
  videoCallStatus  String            @default("IDLE")
  videoCallRoomId  String?
}

model MedicalRecord {
  id            String         @id @default(uuid())
  appointmentId String         @unique
  appointment   Appointment    @relation(fields: [appointmentId], references: [id])
  doctorId      String
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  diagnosis     String
  notes         String?
  prescriptions Prescription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Prescription {
  id              String        @id @default(uuid())
  medicalRecordId String
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  medicationName  String
  dosage          String
  frequency       String
  duration        String
  createdAt       DateTime      @default(now())
}

model Review {
  id            String      @id @default(uuid())
  rating        Int
  comment       String?
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  createdAt     DateTime    @default(now())
}

model HealthProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chronicConditions String?
  allergies         String?
  medications       String?
  familyHistory     String?
  bloodType         String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  title         String
  message       String
  read          Boolean          @default(false)
  appointmentId String?
  appointment   Appointment?     @relation(fields: [appointmentId], references: [id])
  emailSent     Boolean          @default(false)
  scheduledFor  DateTime?
  createdAt     DateTime         @default(now())
}

model MedicalConsentToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
