generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                       String           @id @default(uuid())
  email                                    String           @unique
  password                                 String?
  fullName                                 String?
  avatar                                   String?
  gender                                   String?
  address                                  String?
  province                                 String?
  district                                 String?
  ward                                     String?
  street                                   String?
  dateOfBirth                              DateTime?
  role                                     Role             @default(USER)
  doctorId                                 String?          @unique
  bloodType                                String?
  allergies                                String?
  chronicDiseases                          String?
  personalHistory                          String?
  createdAt                                DateTime         @default(now())
  updatedAt                                DateTime         @updatedAt
  isLocked                                 Boolean          @default(false)
  familyHistory                            String?
  appointments                             Appointment[]
  articles                                 Article[]        @relation("ArticleAuthor")
  complaints                               Complaint[]
  conversations                            Conversation[]
  medicalRecords                           MedicalRecord[]
  messagesSent                             Message[]
  reviews                                  Review[]
  doctor                                   Doctor?          @relation(fields: [doctorId], references: [id])
  calleeVideoCallLogs                      VideoCallLog[]   @relation("VideoCallLog_calleeIdToUser")
  callerVideoCallLogs                      VideoCallLog[]   @relation("VideoCallLog_callerIdToUser")
  notifications                            Notification[]
  voucherUsages                            VoucherUsage[]
  savedVouchers                            SavedVoucher[]
  bookingProfiles                          BookingProfile[]
}

model OTP {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  doctors     Doctor[]
  vouchers    Voucher[]
}

model Doctor {
  id              String              @id @default(uuid())
  name            String
  experience      Int
  hospital        String
  avatar          String
  createdAt       DateTime            @default(now())
  specialtyId     String
  status          DoctorStatus        @default(PENDING)
  isLocked        Boolean             @default(false)
  rejectedReason  String?
  clinicId        String?
  price           Int?
  phone           String?
  description     String?
  appointments    Appointment[]
  conversations   Conversation[]
  clinic          Clinic?             @relation(fields: [clinicId], references: [id])
  specialty       Specialty           @relation(fields: [specialtyId], references: [id])
  certificates    DoctorCertificate[]
  doctorSchedules DoctorSchedule[]
  medicalRecords  MedicalRecord[]
  reviews         Review[]
  userAccount     User?
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  address   String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctors   Doctor[]
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  thumbnail String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String?
  type      String   @default("news")
  author    User?    @relation("ArticleAuthor", fields: [authorId], references: [id])
}

model Complaint {
  id            String          @id @default(cuid())
  message       String
  status        ComplaintStatus @default(PENDING)
  userId        String
  createdAt     DateTime        @default(now())
  adminResponse String?
  appointmentId String?
  appointment   Appointment?    @relation(fields: [appointmentId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
}

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctorId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
}

model Appointment {
  id                 String            @id @default(uuid())
  userId             String
  doctorId           String?
  appointmentDate    DateTime
  status             AppointmentStatus @default(PENDING_PAYMENT)
  notes              String?
  cancellationReason String?
  createdAt          DateTime          @default(now())
  transactionCode    String?           @unique
  amount             Int               @default(50000)
  paymentProof       String?
  paymentAt          DateTime?
  packageId          String?
  patientProfileType PatientProfileType @default(SELF)
  patientInfo        Json?
  voucherCode        String?
  discountAmount     Int?
  absenceProcessed   Boolean           @default(false)
  bookingCode        String?           @unique
  depositForfeited   Boolean           @default(false)
  reminderSent       Boolean           @default(false)
  doctor             Doctor?           @relation(fields: [doctorId], references: [id])
  medicalPackage     MedicalPackage?   @relation(fields: [packageId], references: [id])
  user               User              @relation(fields: [userId], references: [id])
  complaints         Complaint[]
  medicalRecord      MedicalRecord?
  payment            Payment?
  review             Review?
  voucherUsage       VoucherUsage?
}

model MedicalRecord {
  id                   String              @id @default(uuid())
  appointmentId        String              @unique
  doctorId             String
  userId               String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  bloodPressure        String?
  doctorNotes          String?
  finalDiagnosis       String?
  followUpDate         DateTime?
  heartRate            Int?
  height               Float?
  icd10Code            String?
  physicalExam         String?
  preliminaryDiagnosis String?
  severity             SeverityLevel?
  spo2                 Float?
  status               MedicalRecordStatus @default(DRAFT)
  symptoms             String?
  temperature          Float?
  treatmentPlan        String?
  weight               Float?
  LabOrder             LabOrder[]
  appointment          Appointment         @relation(fields: [appointmentId], references: [id])
  doctor               Doctor              @relation(fields: [doctorId], references: [id])
  user                 User                @relation(fields: [userId], references: [id])
  prescriptions        Prescription[]
}

model Prescription {
  id              String        @id @default(uuid())
  medicalRecordId String
  dosage          String
  frequency       String
  createdAt       DateTime      @default(now())
  durationDays    Int
  instructions    String?
  medicineId      String
  quantity        Int
  updatedAt       DateTime      @updatedAt
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  medicine        Medicine      @relation(fields: [medicineId], references: [id])
}

model DoctorCertificate {
  id                 String                        @id @default(cuid())
  doctorId           String
  title              String
  issuer             String?
  issuedYear         Int?
  description        String?
  imageUrl           String?
  fileUrl            String?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  certificateNumber  String?
  expiryYear         Int?
  rejectionReason    String?
  type               CertificateType               @default(OTHER)
  verificationStatus CertificateVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  doctor             Doctor                        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Review {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  doctorId      String
  userId        String
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  doctor        Doctor      @relation(fields: [doctorId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  appointmentId  String        @unique
  amount         Int
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod
  transactionId  String?
  paymentGateway String?
  payDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderCode      BigInt?
  expiredAt      DateTime?
  appointment    Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model MedicalPackage {
  id                 String        @id @default(cuid())
  name               String
  description        String?
  price              Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  estimatedDuration  Int           @default(30)
  hospital           String        @default("Bệnh viện Hoàn Mỹ Đà Nẵng")
  image              String?
  cancellationPolicy String?
  depositAmount      Int?
  depositPercentage  Int           @default(100)
  includedServices   String[]      @default([])
  isRecommended      Boolean       @default(false)
  preparationGuide   String?
  suitableFor        String?
  appointments       Appointment[]
}


model Conversation {
  id        String    @id @default(uuid())
  userId    String
  doctorId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]

  @@unique([userId, doctorId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
}

model AdminLog {
  id          String          @id @default(cuid())
  adminId     String
  adminEmail  String
  action      AdminActionType
  targetType  AdminTargetType
  targetId    String?
  targetLabel String?
  detail      Json?
  ipAddress   String?
  createdAt   DateTime        @default(now())

  @@index([action])
  @@index([adminId])
  @@index([createdAt])
}

model AdminNotification {
  id        String                @id
  type      AdminNotificationType
  title     String
  message   String
  isRead    Boolean               @default(false)
  targetId  String?
  targetUrl String?
  createdAt DateTime              @default(now())

  @@index([createdAt])
  @@index([isRead])
}

model LabOrder {
  id              String         @id @default(cuid())
  medicalRecordId String
  testName        String
  testType        String?
  notes           String?
  status          LabOrderStatus @default(PENDING)
  result          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  MedicalRecord   MedicalRecord  @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
}

model Medicine {
  id                  String         @id @default(cuid())
  name                String
  activeIngredient    String?
  form                String
  unit                String
  defaultInstructions String?
  category            String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  Prescription        Prescription[]
}

model VideoCallLog {
  id                               String    @id @default(uuid())
  appointmentId                    String?
  conversationId                   String?
  callerId                         String
  calleeId                         String
  startedAt                        DateTime
  endedAt                          DateTime?
  durationSeconds                  Int?
  callType                         String
  createdAt                        DateTime  @default(now())
  callee                           User      @relation("VideoCallLog_calleeIdToUser", fields: [calleeId], references: [id])
  caller                           User      @relation("VideoCallLog_callerIdToUser", fields: [callerId], references: [id])
}

enum Role {
  USER
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentMethod {
  VNPAY
  MOCK
  PAYOS
}

enum DoctorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ComplaintStatus {
  PENDING
  RESOLVED
}

enum AdminActionType {
  LOCK_USER
  UNLOCK_USER
  DELETE_USER
  UPDATE_USER_ROLE
  APPROVE_DOCTOR
  REJECT_DOCTOR
  LOCK_DOCTOR
  UNLOCK_DOCTOR
  CREATE_SPECIALTY
  UPDATE_SPECIALTY
  DELETE_SPECIALTY
  CREATE_CLINIC
  UPDATE_CLINIC
  DELETE_CLINIC
  CREATE_ARTICLE
  UPDATE_ARTICLE
  DELETE_ARTICLE
  RESOLVE_COMPLAINT
  UPDATE_APPOINTMENT_STATUS
  REFUND_PAYMENT
  OTHER
  VERIFY_CERTIFICATE
}

enum AdminNotificationType {
  NEW_DOCTOR_PENDING
  NEW_COMPLAINT
  NEW_PAYMENT_PENDING
  ACCOUNT_REPORTED
  BULK_CANCELLATION
  SYSTEM
}

enum AdminTargetType {
  USER
  DOCTOR
  SPECIALTY
  CLINIC
  ARTICLE
  COMPLAINT
  APPOINTMENT
  PAYMENT
  OTHER
  CERTIFICATE
}

enum CertificateType {
  MEDICAL_DEGREE
  PRACTICE_LICENSE
  SPECIALTY
  CLINIC_LICENSE
  ACHIEVEMENT
  OTHER
}

enum CertificateVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum LabOrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum MedicalRecordStatus {
  DRAFT
  COMPLETED
}

enum SeverityLevel {
  MILD
  MODERATE
  SEVERE
  EMERGENCY
}

enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_CANCELLED_BY_DOCTOR
  APPOINTMENT_COMPLETED
  LAB_RESULT_READY
  REFUND_PROCESSED
  NEW_APPOINTMENT
  APPOINTMENT_CANCELLED_BY_PATIENT
  NEW_RATING
  ACCOUNT_APPROVED
  ACCOUNT_REJECTED
  CERTIFICATE_VERIFIED
  NEW_DOCTOR_REGISTRATION
  NEW_COMPLAINT
  PAYMENT_RECEIVED
  CERTIFICATE_PENDING
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum VoucherType {
  PERCENT
  FIXED
}

enum VoucherApplyTo {
  ALL
  PACKAGE
  SPECIALTY
  DOCTOR
}

enum VoucherCategory {
  FIRST_BOOKING
  SPECIALTY
  PACKAGE
  DOCTOR
  REFERRAL
  HOLIDAY
}

model Voucher {
  id               String           @id @default(uuid())
  code             String           @unique @db.VarChar(20)
  type             VoucherType
  discountValue    Int
  applyTo          VoucherApplyTo   @default(ALL)
  category         VoucherCategory  @default(FIRST_BOOKING)
  description      String?          @db.VarChar(255)
  avatarColor      String?          @db.VarChar(20)
  avatarIcon       String?          @db.VarChar(50)
  specialtyId      String?
  minDepositAmount Int              @default(0)
  maxUses          Int?
  usedCount        Int              @default(0)
  isFirstBooking   Boolean          @default(false)
  isActive         Boolean          @default(true)
  startDate        DateTime
  endDate          DateTime
  createdAt        DateTime         @default(now())

  specialty        Specialty?       @relation(fields: [specialtyId], references: [id])
  usages           VoucherUsage[]
  savedVouchers    SavedVoucher[]
}

model VoucherUsage {
  id              String      @id @default(uuid())
  voucherId       String
  userId          String
  appointmentId   String      @unique
  originalDeposit Int
  discountAmount  Int
  finalDeposit    Int
  usedAt          DateTime    @default(now())

  voucher         Voucher     @relation(fields: [voucherId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
}

enum PatientProfileType {
  SELF
  OTHER
}

model BookingProfile {
  id              String    @id @default(cuid())
  userId          String
  fullName        String
  phone           String?
  email           String?
  gender          String?
  dateOfBirth     DateTime?
  relationship    String
  
  // Địa chỉ
  province        String?
  district        String?
  ward            String?
  street          String?
  
  // Thông tin sức khỏe
  bloodType       String?
  allergies       String?
  chronicDiseases String?
  personalHistory String?
  familyHistory   String?
  
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])
}

model SavedVoucher {
  id        String   @id @default(uuid())
  userId    String
  voucherId String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([userId, voucherId])
}
