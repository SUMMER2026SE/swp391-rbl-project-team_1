# ==========================================
# HEALTHCARE BOOKING BACKEND CONFIGURATION
# ==========================================

# Port to run the server on (defaults to 5000)
PORT=5000

# Environment state (production / development / test)
NODE_ENV=production

# Supabase — copy from Dashboard → Project Settings → Database → Connection string
# App (pooler 6543): postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.jgvjldvfahpyousigmsa:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Secret key used to sign and verify JWT tokens.
# IMPORTANT: In production, use a strong, cryptographically secure key (e.g. 64 random characters).
# You can generate one via command line: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your_extremely_long_and_cryptographically_secure_jwt_secret_key"

# CORS Allowed Origins
# Specify the production URL of your Frontend (e.g. Vercel deployment URL).
# Support multiple origins separated by commas (no spaces). Use "*" to allow all (not recommended for production).
CORS_ORIGIN="https://healthcare-booking-frontend.vercel.app,http://localhost:3000"

# Google Gemini API Key for Clinical Diagnosis AI Chatbot (Optional - system falls back to a smart local Vietnamese engine if empty)
GEMINI_API_KEY="your_google_gemini_api_key"
